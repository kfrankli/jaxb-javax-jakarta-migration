      "link": null,
      "locked": false,
      "text": "It is very easy to create a modified\napplication that will successfully compiles\nbut fails to run due to calling a javax.xml\nclass when a jakarta.xml class was\nneeded or vice versa",
      "fontSize": 28,
      "fontFamily": 6,
